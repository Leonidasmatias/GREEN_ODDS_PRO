generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id          String   @id @default(cuid())
  providerId  String?  @unique
  competition String
  homeTeam    String
  awayTeam    String
  startsAt    DateTime
  status      String   @default("PRE_GAME")
  homeScore   Int?
  awayScore   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tips        Tip[]
  oddsSnapshots OddsSnapshot[]

  @@index([startsAt, status])
  @@map("matches")
}

model OddsSnapshot {
  id         String   @id @default(cuid())
  matchId    String
  market     String
  selection  String
  odd        Float
  provider   String
  capturedAt DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, market, capturedAt])
  @@index([provider, capturedAt])
  @@map("odds_snapshots")
}

model ValueAnalysis {
  id                   String   @id @default(cuid())
  matchId              String
  oddsSnapshotId       String?
  provider             String
  market               String
  selection            String
  odd                  Float
  impliedProbability   Float
  bookmakerMargin      Float
  fairOdd              Float
  estimatedProbability Float?
  edge                 Float?
  expectedValue        Float?
  risk                 String
  classification       String
  status               String
  rejectionReasons     String?
  historicalSample     Int      @default(0)
  confidence           Float    @default(0)
  score                Float    @default(0)
  analyzedAt           DateTime @default(now())

  @@index([provider, analyzedAt])
  @@index([status, classification])
  @@map("value_analyses")
}

model Tip {
  id                 String   @id @default(cuid())
  matchId            String
  gameLabel          String
  market             String
  selection          String
  odd                Float
  provider           String   @default("unknown")
  bookmaker          String   @default("unknown")
  impliedProbability Float
  estimatedProbability Float
  edge               Float
  expectedValue      Float
  confidenceScore    Float
  score              Float    @default(0)
  classification     String
  risk               String
  status             String   @default("PENDING")
  stakeSuggested     Float    @default(1)
  stake              Float    @default(1)
  profit             Float?
  profitLoss         Float?
  roi                Float?
  rejectionReason    String?
  createdAt          DateTime @default(now())
  settledAt          DateTime?
  match              Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  results            TipResult[]

  @@index([status, createdAt])
  @@index([expectedValue, confidenceScore])
  @@index([provider, bookmaker])
  @@map("tips")
}

model TipResult {
  id              String   @id @default(cuid())
  tipId           String   @unique
  matchId         String
  market          String
  selection       String
  status          String
  homeScore       Int?
  awayScore       Int?
  profit          Float
  roi             Float
  provider        String
  bookmaker       String
  rejectionReason String?
  settledAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  tip             Tip      @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@index([status, settledAt])
  @@index([market, selection])
  @@map("tip_results")
}

model SettlementRun {
  id            String   @id @default(cuid())
  provider      String
  status        String   @default("RUNNING")
  tipsProcessed Int      @default(0)
  tipsSettled   Int      @default(0)
  errors        String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([provider, startedAt])
  @@index([status, startedAt])
  @@map("settlement_runs")
}

model MarketPerformance {
  id              String   @id @default(cuid())
  market          String
  selection       String
  sport           String
  provider        String
  bookmaker       String
  oddRange        String
  totalEntries    Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  averageOdd      Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  maxDrawdown     Float    @default(0)
  confidenceScore Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([market, selection, sport, provider, bookmaker, oddRange])
  @@index([market, provider])
  @@index([roi, winRate])
  @@map("market_performance")
}

model MarketRanking {
  id              String   @id @default(cuid())
  market          String
  competition     String
  provider        String
  bookmaker       String
  oddRange        String
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([market, competition, provider, bookmaker, oddRange])
  @@index([roi, winRate])
  @@map("market_rankings")
}

model CompetitionRanking {
  id              String   @id @default(cuid())
  competition     String
  provider        String
  oddRange        String
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([competition, provider, oddRange])
  @@index([roi, winRate])
  @@map("competition_rankings")
}

model BookmakerRanking {
  id              String   @id @default(cuid())
  bookmaker       String
  provider        String
  oddRange        String
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([bookmaker, provider, oddRange])
  @@index([roi, winRate])
  @@map("bookmaker_rankings")
}

model MarketConfidence {
  id              String   @id @default(cuid())
  market          String
  provider        String
  bookmaker       String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([market, provider, bookmaker])
  @@index([confidenceScore, roi])
  @@map("market_confidence")
}

model CompetitionConfidence {
  id              String   @id @default(cuid())
  competition     String
  provider        String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([competition, provider])
  @@index([confidenceScore, roi])
  @@map("competition_confidence")
}

model BookmakerConfidence {
  id              String   @id @default(cuid())
  bookmaker       String
  provider        String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([bookmaker, provider])
  @@index([confidenceScore, roi])
  @@map("bookmaker_confidence")
}

model OddRangeConfidence {
  id              String   @id @default(cuid())
  oddRange        String
  provider        String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([oddRange, provider])
  @@index([confidenceScore, roi])
  @@map("odd_range_confidence")
}

model MlTrainingRun {
  id                  String    @id @default(cuid())
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  status              String    @default("RUNNING")
  totalSamples        Int       @default(0)
  wonSamples          Int       @default(0)
  lostSamples         Int       @default(0)
  voidSamples         Int       @default(0)
  marketsCovered      Int       @default(0)
  competitionsCovered Int       @default(0)
  bookmakersCovered   Int       @default(0)
  modelVersion        String
  notes               String?
  metrics             MlModelMetric[]

  @@index([status, startedAt])
  @@index([modelVersion])
  @@map("ml_training_runs")
}

model MlModelMetric {
  id              String        @id @default(cuid())
  trainingRunId   String
  accuracy        Float         @default(0)
  precision       Float         @default(0)
  recall          Float         @default(0)
  roiBacktest     Float         @default(0)
  winRateBacktest Float         @default(0)
  sampleSize      Int           @default(0)
  createdAt       DateTime      @default(now())
  trainingRun     MlTrainingRun @relation(fields: [trainingRunId], references: [id], onDelete: Cascade)

  @@index([trainingRunId])
  @@index([createdAt])
  @@map("ml_model_metrics")
}

model MlPrediction {
  id                 String   @id @default(cuid())
  matchId            String
  market             String
  selection          String
  provider           String
  bookmaker          String
  odd                Float
  impliedProbability Float
  modelProbability   Float
  edge               Float
  confidenceScore    Float
  classification     String
  status             String
  createdAt          DateTime @default(now())

  @@index([matchId, market, selection])
  @@index([provider, createdAt])
  @@index([status, classification])
  @@map("ml_predictions")
}

model DiscoveryRun {
  id                       String                    @id @default(cuid())
  startedAt                DateTime                  @default(now())
  finishedAt               DateTime?
  status                   String                    @default("RUNNING")
  totalTipsAnalyzed        Int                       @default(0)
  patternsFound            Int                       @default(0)
  recommendationsGenerated Int                       @default(0)
  modelVersion             String
  notes                    String?
  patterns                 DiscoveryPattern[]
  recommendations          DiscoveryRecommendation[]

  @@index([status, startedAt])
  @@index([modelVersion])
  @@map("discovery_runs")
}

model DiscoveryPattern {
  id              String                    @id @default(cuid())
  runId           String
  patternType     String
  market          String?
  competition     String?
  bookmaker       String?
  provider        String?
  oddRange        String?
  sampleSize      Int                       @default(0)
  winRate         Float                     @default(0)
  roi             Float                     @default(0)
  profit          Float                     @default(0)
  drawdown        Float                     @default(0)
  confidenceScore Float                     @default(0)
  mlScore         Float                     @default(0)
  status          String                    @default("INSUFFICIENT_REAL_DATA")
  createdAt       DateTime                  @default(now())
  run             DiscoveryRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  recommendations DiscoveryRecommendation[]

  @@index([runId])
  @@index([patternType, status])
  @@index([market, provider, bookmaker, oddRange])
  @@map("discovery_patterns")
}

model DiscoveryRecommendation {
  id                 String           @id @default(cuid())
  runId              String
  patternId          String?
  title              String
  description        String
  recommendationType String
  priority           String
  status             String
  reason             String
  createdAt          DateTime         @default(now())
  run                DiscoveryRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  pattern            DiscoveryPattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([patternId])
  @@index([recommendationType, status])
  @@map("discovery_recommendations")
}

model SyncRun {
  id                String   @id @default(cuid())
  provider          String
  mode              String
  status            String
  eventsReceived    Int      @default(0)
  snapshotsCreated  Int      @default(0)
  tipsCreated       Int      @default(0)
  requestsRemaining Int?
  warning           String?
  startedAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([startedAt])
  @@map("sync_runs")
}

model Performance {
  id                String   @id @default(cuid())
  periodStart       DateTime
  periodEnd         DateTime
  totalEntries      Int
  greens            Int
  reds              Int
  pending           Int
  totalStake        Float
  accumulatedProfit Float
  roi               Float
  hitRate           Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([periodStart, periodEnd])
  @@map("performance")
}

model ModelWeights {
  id         String   @id @default("default")
  form       Float    @default(20)
  attack     Float    @default(20)
  defense    Float    @default(20)
  momentum   Float    @default(15)
  ranking    Float    @default(10)
  statistics Float    @default(15)
  updatedAt  DateTime @updatedAt

  @@map("model_weights")
}

model TrainingDataset {
  id        String   @id @default(cuid())
  tipId     String   @unique
  matchId   String
  market    String
  odd       Float
  impliedProbability Float @default(0)
  estimatedProbability Float @default(0)
  score     Float
  ev        Float
  edge      Float @default(0)
  risk      String
  result    String
  profit    Float
  generatedAt DateTime @default(now())
  settledAt DateTime @default(now())
  oddsMovement Float @default(0)
  powerRating Float @default(0)
  recentForm Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([market, result])
  @@index([createdAt])
  @@index([settledAt])
  @@map("training_dataset")
}

model AuditLog {
  id        String   @id @default(cuid())
  category  String
  status    String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([status, createdAt])
  @@map("audit_logs")
}

model ModelVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  trainedAt   DateTime @default(now())
  recordsUsed Int
  winRate     Float
  roi         Float
  yield       Float
  accuracy    Float
  precision   Float
  recall      Float
  notes       String?

  @@index([trainedAt])
  @@map("model_versions")
}

model JobRun {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("PENDING")
  scheduledAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  message     String?
  metadata    String?

  @@index([name, scheduledAt])
  @@index([status, scheduledAt])
  @@map("job_runs")
}

model DataQualityAlert {
  id        String   @id @default(cuid())
  type      String
  severity  String
  status    String   @default("OPEN")
  message   String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
  resolvedAt DateTime?

  @@index([status, severity])
  @@index([type, createdAt])
  @@map("data_quality_alerts")
}

model ProviderCall {
  id               String   @id @default(cuid())
  provider         String
  operation        String
  status           String
  latencyMs        Int
  callsMade        Int      @default(1)
  remainingLimit   Int?
  error            String?
  createdAt        DateTime @default(now())

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@map("provider_calls")
}

model SchedulerLease {
  id        String   @id
  ownerId   String
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("scheduler_leases")
}
