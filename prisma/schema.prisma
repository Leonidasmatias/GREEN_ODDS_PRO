generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id          String   @id @default(cuid())
  providerId  String?  @unique
  competition String
  homeTeam    String
  awayTeam    String
  startsAt    DateTime
  status      String   @default("PRE_GAME")
  homeScore   Int?
  awayScore   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tips        Tip[]
  oddsSnapshots OddsSnapshot[]
  results     MatchResult[]

  @@index([startsAt, status])
  @@map("matches")
}

model OddsSnapshot {
  id         String   @id @default(cuid())
  matchId    String
  market     String
  selection  String
  odd        Float
  provider   String
  capturedAt DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, market, capturedAt])
  @@index([provider, capturedAt])
  @@map("odds_snapshots")
}

model ValueAnalysis {
  id                   String   @id @default(cuid())
  matchId              String
  oddsSnapshotId       String?
  provider             String
  market               String
  selection            String
  odd                  Float
  impliedProbability   Float
  bookmakerMargin      Float
  fairOdd              Float
  estimatedProbability Float?
  edge                 Float?
  expectedValue        Float?
  risk                 String
  classification       String
  status               String
  rejectionReasons     String?
  historicalSample     Int      @default(0)
  confidence           Float    @default(0)
  score                Float    @default(0)
  analyzedAt           DateTime @default(now())

  @@index([provider, analyzedAt])
  @@index([status, classification])
  @@map("value_analyses")
}

model GreenScoreAnalysis {
  id                   String   @id @default(cuid())
  matchId              String
  oddsSnapshotId       String?
  provider             String
  bookmaker            String
  competition          String
  gameLabel            String
  market               String
  selection            String
  odd                  Float
  greenScore           Int
  confidence           Int
  risk                 String
  classification       String
  qualifiesOddsOfDay   Boolean  @default(false)
  valueScore           Float    @default(0)
  valueStatus          String
  mlStatus             String
  mlConfidence         Float    @default(0)
  discoveryStatus      String?
  riskShieldStatus     String
  rejectionReasons     String?
  analyzedAt           DateTime @default(now())
  createdAt            DateTime @default(now())

  @@index([greenScore, confidence, risk])
  @@index([classification, analyzedAt])
  @@index([qualifiesOddsOfDay, analyzedAt])
  @@map("green_score_analyses")
}

model Tip {
  id                 String   @id @default(cuid())
  matchId            String
  gameLabel          String
  market             String
  selection          String
  odd                Float
  provider           String   @default("unknown")
  bookmaker          String   @default("unknown")
  impliedProbability Float
  estimatedProbability Float
  edge               Float
  expectedValue      Float
  confidenceScore    Float
  score              Float    @default(0)
  classification     String
  risk               String
  status             String   @default("PENDING")
  stakeSuggested     Float    @default(1)
  stake              Float    @default(1)
  profit             Float?
  profitLoss         Float?
  roi                Float?
  rejectionReason    String?
  createdAt          DateTime @default(now())
  settledAt          DateTime?
  match              Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  results            TipResult[]

  @@index([status, createdAt])
  @@index([expectedValue, confidenceScore])
  @@index([provider, bookmaker])
  @@map("tips")
}

model TipResult {
  id              String   @id @default(cuid())
  tipId           String   @unique
  matchId         String
  market          String
  selection       String
  status          String
  homeScore       Int?
  awayScore       Int?
  profit          Float
  roi             Float
  provider        String
  bookmaker       String
  rejectionReason String?
  settledAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  tip             Tip      @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@index([status, settledAt])
  @@index([market, selection])
  @@map("tip_results")
}

model SettlementRun {
  id            String   @id @default(cuid())
  provider      String
  status        String   @default("RUNNING")
  tipsProcessed Int      @default(0)
  tipsSettled   Int      @default(0)
  errors        String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([provider, startedAt])
  @@index([status, startedAt])
  @@map("settlement_runs")
}

model MatchResult {
  id          String   @id @default(cuid())
  matchId     String
  providerId  String
  provider    String
  competition String
  homeTeam    String
  awayTeam    String
  homeScore   Int?
  awayScore   Int?
  status      String   @default("PENDING")
  source      String   @default("PROVIDER")
  rawPayload  String?
  collectedAt DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([matchId, status])
  @@index([provider, collectedAt])
  @@map("match_results")
}

model ResultSyncRun {
  id               String   @id @default(cuid())
  provider         String
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  status           String   @default("RUNNING")
  resultsReceived  Int      @default(0)
  resultsPersisted Int      @default(0)
  matchesUpdated   Int      @default(0)
  pendingResults   Int      @default(0)
  remainingLimit   Int?
  errors           String?
  notes            String?

  @@index([provider, startedAt])
  @@index([status, startedAt])
  @@map("result_sync_runs")
}

model SettlementAudit {
  id              String   @id @default(cuid())
  provider        String
  resultSyncRunId String?
  settlementRunId String?
  resultsSynced   Int      @default(0)
  tipsProcessed   Int      @default(0)
  tipsSettled     Int      @default(0)
  won             Int      @default(0)
  lost            Int      @default(0)
  voids           Int      @default(0)
  pending         Int      @default(0)
  settlementRate  Float    @default(0)
  status          String   @default("SUCCESS")
  reason          String?
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@index([resultSyncRunId])
  @@map("settlement_audits")
}

model MarketPerformance {
  id              String   @id @default(cuid())
  market          String
  selection       String
  sport           String
  provider        String
  bookmaker       String
  oddRange        String
  totalEntries    Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  averageOdd      Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  maxDrawdown     Float    @default(0)
  confidenceScore Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([market, selection, sport, provider, bookmaker, oddRange])
  @@index([market, provider])
  @@index([roi, winRate])
  @@map("market_performance")
}

model MarketRanking {
  id              String   @id @default(cuid())
  market          String
  competition     String
  provider        String
  bookmaker       String
  oddRange        String
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([market, competition, provider, bookmaker, oddRange])
  @@index([roi, winRate])
  @@map("market_rankings")
}

model CompetitionRanking {
  id              String   @id @default(cuid())
  competition     String
  provider        String
  oddRange        String
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([competition, provider, oddRange])
  @@index([roi, winRate])
  @@map("competition_rankings")
}

model BookmakerRanking {
  id              String   @id @default(cuid())
  bookmaker       String
  provider        String
  oddRange        String
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([bookmaker, provider, oddRange])
  @@index([roi, winRate])
  @@map("bookmaker_rankings")
}

model MarketConfidence {
  id              String   @id @default(cuid())
  market          String
  provider        String
  bookmaker       String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([market, provider, bookmaker])
  @@index([confidenceScore, roi])
  @@map("market_confidence")
}

model CompetitionConfidence {
  id              String   @id @default(cuid())
  competition     String
  provider        String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([competition, provider])
  @@index([confidenceScore, roi])
  @@map("competition_confidence")
}

model BookmakerConfidence {
  id              String   @id @default(cuid())
  bookmaker       String
  provider        String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([bookmaker, provider])
  @@index([confidenceScore, roi])
  @@map("bookmaker_confidence")
}

model OddRangeConfidence {
  id              String   @id @default(cuid())
  oddRange        String
  provider        String
  sampleSize      Int      @default(0)
  totalTips       Int      @default(0)
  wins            Int      @default(0)
  losses          Int      @default(0)
  voids           Int      @default(0)
  winRate         Float    @default(0)
  roi             Float    @default(0)
  profit          Float    @default(0)
  drawdown        Float    @default(0)
  confidenceScore Float    @default(0)
  status          String   @default("INSUFFICIENT_REAL_DATA")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([oddRange, provider])
  @@index([confidenceScore, roi])
  @@map("odd_range_confidence")
}

model MlTrainingRun {
  id                  String    @id @default(cuid())
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  status              String    @default("RUNNING")
  totalSamples        Int       @default(0)
  wonSamples          Int       @default(0)
  lostSamples         Int       @default(0)
  voidSamples         Int       @default(0)
  marketsCovered      Int       @default(0)
  competitionsCovered Int       @default(0)
  bookmakersCovered   Int       @default(0)
  modelVersion        String
  notes               String?
  metrics             MlModelMetric[]

  @@index([status, startedAt])
  @@index([modelVersion])
  @@map("ml_training_runs")
}

model MlModelMetric {
  id              String        @id @default(cuid())
  trainingRunId   String
  accuracy        Float         @default(0)
  precision       Float         @default(0)
  recall          Float         @default(0)
  roiBacktest     Float         @default(0)
  winRateBacktest Float         @default(0)
  sampleSize      Int           @default(0)
  createdAt       DateTime      @default(now())
  trainingRun     MlTrainingRun @relation(fields: [trainingRunId], references: [id], onDelete: Cascade)

  @@index([trainingRunId])
  @@index([createdAt])
  @@map("ml_model_metrics")
}

model MlPrediction {
  id                 String   @id @default(cuid())
  matchId            String
  market             String
  selection          String
  provider           String
  bookmaker          String
  odd                Float
  impliedProbability Float
  modelProbability   Float
  edge               Float
  confidenceScore    Float
  classification     String
  status             String
  createdAt          DateTime @default(now())

  @@index([matchId, market, selection])
  @@index([provider, createdAt])
  @@index([status, classification])
  @@map("ml_predictions")
}

model DiscoveryRun {
  id                       String                    @id @default(cuid())
  startedAt                DateTime                  @default(now())
  finishedAt               DateTime?
  status                   String                    @default("RUNNING")
  totalTipsAnalyzed        Int                       @default(0)
  patternsFound            Int                       @default(0)
  recommendationsGenerated Int                       @default(0)
  modelVersion             String
  notes                    String?
  patterns                 DiscoveryPattern[]
  recommendations          DiscoveryRecommendation[]

  @@index([status, startedAt])
  @@index([modelVersion])
  @@map("discovery_runs")
}

model DiscoveryPattern {
  id              String                    @id @default(cuid())
  runId           String
  patternType     String
  market          String?
  competition     String?
  bookmaker       String?
  provider        String?
  oddRange        String?
  sampleSize      Int                       @default(0)
  winRate         Float                     @default(0)
  roi             Float                     @default(0)
  profit          Float                     @default(0)
  drawdown        Float                     @default(0)
  confidenceScore Float                     @default(0)
  mlScore         Float                     @default(0)
  status          String                    @default("INSUFFICIENT_REAL_DATA")
  createdAt       DateTime                  @default(now())
  run             DiscoveryRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  recommendations DiscoveryRecommendation[]

  @@index([runId])
  @@index([patternType, status])
  @@index([market, provider, bookmaker, oddRange])
  @@map("discovery_patterns")
}

model DiscoveryRecommendation {
  id                 String           @id @default(cuid())
  runId              String
  patternId          String?
  title              String
  description        String
  recommendationType String
  priority           String
  status             String
  reason             String
  createdAt          DateTime         @default(now())
  run                DiscoveryRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  pattern            DiscoveryPattern? @relation(fields: [patternId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([patternId])
  @@index([recommendationType, status])
  @@map("discovery_recommendations")
}

model BankrollProfile {
  id                     String   @id @default(cuid())
  name                   String
  initialBankroll        Float
  currentBankroll        Float
  currency               String   @default("BRL")
  riskProfile            String   @default("CONSERVADOR")
  maxDailyRiskPercent    Float    @default(2)
  maxStakePercent        Float    @default(1)
  maxOpenExposurePercent Float    @default(5)
  stopLossDailyPercent   Float    @default(5)
  stopWinDailyPercent    Float    @default(5)
  status                 String   @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([status, createdAt])
  @@map("bankroll_profiles")
}

model BankrollAllocation {
  id          String   @id @default(cuid())
  profileId   String
  category    String
  allocated   Float    @default(0)
  used        Float    @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([profileId, category])
  @@map("bankroll_allocations")
}

model ExposureLimit {
  id           String   @id @default(cuid())
  profileId    String
  scope        String
  scopeValue   String
  maxPercent   Float
  currentValue Float    @default(0)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([profileId, scope, scopeValue])
  @@map("exposure_limits")
}

model StakeRecommendation {
  id                 String   @id @default(cuid())
  tipId              String?
  matchId            String
  market             String
  selection          String
  odd                Float
  confidenceScore    Float
  modelProbability   Float?
  edge               Float?
  expectedValue      Float?
  risk               String
  recommendedStake   Float    @default(0)
  stakePercent       Float    @default(0)
  strategy           String
  status             String
  reason             String
  createdAt          DateTime @default(now())

  @@index([tipId])
  @@index([matchId, market, selection])
  @@index([status, createdAt])
  @@map("stake_recommendations")
}

model BankrollEvent {
  id        String   @id @default(cuid())
  profileId String?
  eventType String
  amount    Float    @default(0)
  balance   Float    @default(0)
  note      String?
  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@index([eventType, createdAt])
  @@map("bankroll_events")
}

model RiskRule {
  id        String   @id @default(cuid())
  name      String
  ruleType  String
  threshold Float
  severity  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ruleType, enabled])
  @@map("risk_rules")
}

model RiskEvent {
  id        String   @id @default(cuid())
  tipId     String?
  eventType String
  severity  String
  action    String
  reason    String
  createdAt DateTime @default(now())

  @@index([tipId])
  @@index([eventType, createdAt])
  @@index([action, severity])
  @@map("risk_events")
}

model ExposureSnapshot {
  id                  String   @id @default(cuid())
  bankrollProfileId   String?
  date                DateTime
  totalExposure       Float    @default(0)
  dailyRiskUsed       Float    @default(0)
  openTips            Int      @default(0)
  marketExposure      String
  competitionExposure String
  bookmakerExposure   String
  createdAt           DateTime @default(now())

  @@index([bankrollProfileId, date])
  @@index([createdAt])
  @@map("exposure_snapshots")
}

model CorrelationBlock {
  id          String   @id @default(cuid())
  matchId     String
  market      String
  competition String
  reason      String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  @@index([matchId, status])
  @@index([competition, status])
  @@map("correlation_blocks")
}

model PerformanceAttributionRun {
  id                String                          @id @default(cuid())
  startedAt         DateTime                        @default(now())
  finishedAt        DateTime?
  status            String                          @default("RUNNING")
  totalTipsAnalyzed Int                             @default(0)
  segmentsAnalyzed  Int                             @default(0)
  insightsGenerated Int                             @default(0)
  modelVersion      String
  notes             String?
  segments          PerformanceAttributionSegment[]
  insights          PerformanceAttributionInsight[]

  @@index([status, startedAt])
  @@index([modelVersion])
  @@map("performance_attribution_runs")
}

model PerformanceAttributionSegment {
  id                String                    @id @default(cuid())
  runId             String
  segmentType       String
  segmentKey        String
  market            String?
  competition       String?
  bookmaker         String?
  provider          String?
  oddRange          String?
  classification    String?
  risk              String?
  confidenceRange   String?
  mlStatus          String?
  discoveryStatus   String?
  riskShieldAction  String?
  bankrollStrategy  String?
  totalTips         Int                       @default(0)
  wins              Int                       @default(0)
  losses            Int                       @default(0)
  voids             Int                       @default(0)
  winRate           Float                     @default(0)
  roi               Float                     @default(0)
  profit            Float                     @default(0)
  averageOdd        Float                     @default(0)
  averageStake      Float                     @default(0)
  drawdown          Float                     @default(0)
  hitRateByOddRange Float                     @default(0)
  edgeRealizado     Float                     @default(0)
  evRealizado       Float                     @default(0)
  variance          Float                     @default(0)
  sharpeLikeScore   Float                     @default(0)
  maxLosingStreak   Int                       @default(0)
  maxWinningStreak  Int                       @default(0)
  status            String                    @default("INSUFFICIENT_REAL_DATA")
  createdAt         DateTime                  @default(now())
  run               PerformanceAttributionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([segmentType, status])
  @@index([market, provider, bookmaker, oddRange])
  @@map("performance_attribution_segments")
}

model PerformanceAttributionInsight {
  id          String                    @id @default(cuid())
  runId       String
  insightType String
  title       String
  description String
  severity    String
  status      String
  segmentType String?
  segmentKey  String?
  metricValue Float?
  createdAt   DateTime                  @default(now())
  run         PerformanceAttributionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([insightType, status])
  @@map("performance_attribution_insights")
}

model AdaptiveStrategyRun {
  id                   String                       @id @default(cuid())
  startedAt            DateTime                     @default(now())
  finishedAt           DateTime?
  status               String                       @default("RUNNING")
  totalTipsAnalyzed    Int                          @default(0)
  segmentsAnalyzed     Int                          @default(0)
  adjustmentsGenerated Int                          @default(0)
  adjustmentsApplied   Int                          @default(0)
  blockedSegments      Int                          @default(0)
  modelVersion         String
  notes                String?
  adjustments          AdaptiveStrategyAdjustment[]
  events               AdaptiveStrategyEvent[]

  @@index([status, startedAt])
  @@index([modelVersion])
  @@map("adaptive_strategy_runs")
}

model AdaptiveStrategyRule {
  id                       String    @id @default(cuid())
  segmentType              String
  segmentKey               String
  market                   String?
  competition              String?
  bookmaker                String?
  provider                 String?
  oddRange                 String?
  action                   String
  weightMultiplier         Float     @default(1)
  confidenceThresholdDelta Float     @default(0)
  stakeMultiplier          Float     @default(1)
  riskSensitivity          String    @default("NORMAL")
  status                   String    @default("ACTIVE")
  reason                   String
  sampleSize               Int       @default(0)
  roi                      Float     @default(0)
  drawdown                 Float     @default(0)
  variance                 Float     @default(0)
  sourceRunId              String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@unique([segmentType, segmentKey])
  @@index([status, action])
  @@index([market, provider, bookmaker, oddRange])
  @@map("adaptive_strategy_rules")
}

model AdaptiveStrategyAdjustment {
  id                       String              @id @default(cuid())
  runId                    String
  ruleId                   String?
  segmentType              String
  segmentKey               String
  action                   String
  weightMultiplier         Float               @default(1)
  confidenceThresholdDelta Float               @default(0)
  stakeMultiplier          Float               @default(1)
  riskSensitivity          String              @default("NORMAL")
  sampleSize               Int                 @default(0)
  roi                      Float               @default(0)
  drawdown                 Float               @default(0)
  variance                 Float               @default(0)
  status                   String              @default("PENDING")
  reason                   String
  appliedAt                DateTime?
  createdAt                DateTime            @default(now())
  run                      AdaptiveStrategyRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([segmentType, action])
  @@index([status, createdAt])
  @@map("adaptive_strategy_adjustments")
}

model AdaptiveStrategyEvent {
  id        String              @id @default(cuid())
  runId     String?
  eventType String
  severity  String
  action    String
  reason    String
  metadata  String?
  createdAt DateTime            @default(now())
  run       AdaptiveStrategyRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([eventType, severity])
  @@index([createdAt])
  @@map("adaptive_strategy_events")
}

model SyncRun {
  id                String   @id @default(cuid())
  provider          String
  mode              String
  status            String
  eventsReceived    Int      @default(0)
  snapshotsCreated  Int      @default(0)
  tipsCreated       Int      @default(0)
  requestsRemaining Int?
  warning           String?
  startedAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([startedAt])
  @@map("sync_runs")
}

model Performance {
  id                String   @id @default(cuid())
  periodStart       DateTime
  periodEnd         DateTime
  totalEntries      Int
  greens            Int
  reds              Int
  pending           Int
  totalStake        Float
  accumulatedProfit Float
  roi               Float
  hitRate           Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([periodStart, periodEnd])
  @@map("performance")
}

model ModelWeights {
  id         String   @id @default("default")
  form       Float    @default(20)
  attack     Float    @default(20)
  defense    Float    @default(20)
  momentum   Float    @default(15)
  ranking    Float    @default(10)
  statistics Float    @default(15)
  updatedAt  DateTime @updatedAt

  @@map("model_weights")
}

model TrainingDataset {
  id        String   @id @default(cuid())
  tipId     String   @unique
  matchId   String
  market    String
  odd       Float
  impliedProbability Float @default(0)
  estimatedProbability Float @default(0)
  score     Float
  ev        Float
  edge      Float @default(0)
  risk      String
  result    String
  profit    Float
  generatedAt DateTime @default(now())
  settledAt DateTime @default(now())
  oddsMovement Float @default(0)
  powerRating Float @default(0)
  recentForm Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([market, result])
  @@index([createdAt])
  @@index([settledAt])
  @@map("training_dataset")
}

model AuditLog {
  id        String   @id @default(cuid())
  category  String
  status    String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([status, createdAt])
  @@map("audit_logs")
}

model ModelVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  trainedAt   DateTime @default(now())
  recordsUsed Int
  winRate     Float
  roi         Float
  yield       Float
  accuracy    Float
  precision   Float
  recall      Float
  notes       String?

  @@index([trainedAt])
  @@map("model_versions")
}

model JobRun {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("PENDING")
  scheduledAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  message     String?
  metadata    String?

  @@index([name, scheduledAt])
  @@index([status, scheduledAt])
  @@map("job_runs")
}

model DataQualityRun {
  id             String             @id @default(cuid())
  startedAt      DateTime           @default(now())
  finishedAt     DateTime?
  status         String             @default("RUNNING")
  score          Int                @default(100)
  classification String             @default("EXCELLENT")
  checksRun      Int                @default(0)
  alertsFound    Int                @default(0)
  criticalCount  Int                @default(0)
  warningCount   Int                @default(0)
  notes          String?
  alerts         DataQualityAlert[]
  events         DataQualityEvent[]

  @@index([status, startedAt])
  @@index([classification, score])
  @@map("data_quality_runs")
}

model DataQualityEvent {
  id        String          @id @default(cuid())
  runId     String?
  eventType String
  severity  String
  entity    String?
  entityId  String?
  message   String
  metadata  String?
  createdAt DateTime        @default(now())
  run       DataQualityRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([eventType, severity])
  @@index([createdAt])
  @@map("data_quality_events")
}

model DataQualityAlert {
  id        String   @id @default(cuid())
  runId     String?
  type      String
  severity  String
  status    String   @default("OPEN")
  entity    String?
  message   String
  entityId  String?
  scoreImpact Int    @default(0)
  metadata  String?
  createdAt DateTime @default(now())
  resolvedAt DateTime?
  run       DataQualityRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([status, severity])
  @@index([type, createdAt])
  @@map("data_quality_alerts")
}

model ProviderCall {
  id               String   @id @default(cuid())
  provider         String
  operation        String
  status           String
  latencyMs        Int
  callsMade        Int      @default(1)
  remainingLimit   Int?
  error            String?
  createdAt        DateTime @default(now())

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@map("provider_calls")
}

model ProviderCache {
  id        String   @id @default(cuid())
  provider  String
  cacheKey  String
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, cacheKey])
  @@index([provider, expiresAt])
  @@map("provider_cache")
}

model ProviderUsageLog {
  id               String   @id @default(cuid())
  provider         String
  endpoint         String
  status           Int
  creditsUsed      Int      @default(1)
  creditsRemaining Int?
  createdAt        DateTime @default(now())

  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@map("provider_usage_logs")
}
model User {
  id             String             @id @default(cuid())
  name           String?
  email          String             @unique
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  role           String             @default("USER")
  status         String             @default("ACTIVE")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accounts       Account[]
  sessions       Session[]
  subscriptions  UserSubscription[]
  accessLogs     AccessLog[]

  @@index([status, createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SubscriptionPlan {
  id                 String             @id @default(cuid())
  code               String             @unique
  name               String
  description        String?
  maxPicksPerDay     Int?
  greenAiReportLevel String             @default("NONE")
  commandCenterLevel String             @default("NONE")
  radarAccess        Boolean            @default(false)
  oddsAccess         Boolean            @default(false)
  alertsAccess       Boolean            @default(false)
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  subscriptions      UserSubscription[]

  @@index([active, code])
  @@map("subscription_plans")
}

model UserSubscription {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  status    String   @default("ACTIVE")
  startsAt  DateTime @default(now())
  endsAt    DateTime?
  source    String   @default("INTERNAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([planId, status])
  @@map("user_subscriptions")
}

model AccessLog {
  id        String   @id @default(cuid())
  userId    String?
  route     String
  action    String
  status    String
  planCode  String?
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([route, status, createdAt])
  @@map("access_logs")
}

model SchedulerLease {
  id        String   @id
  ownerId   String
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("scheduler_leases")
}
